{
  "name": "klock",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:sdk": "node \"$npm_execpath\" --workspace @pulseprotocol/sdk run build",
    "build:react": "node \"$npm_execpath\" --workspace @pulseprotocol/react run build",
    "build:packages": "node \"$npm_execpath\" run build:sdk && node \"$npm_execpath\" run build:react",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test:sdk": "node \"$npm_execpath\" --workspace @pulseprotocol/sdk run test",
    "test:react": "node \"$npm_execpath\" --workspace @pulseprotocol/react run test",
    "test:packages": "node \"$npm_execpath\" run test:sdk && node \"$npm_execpath\" run test:react",
    "release:check": "node \"$npm_execpath\" run build:packages && node \"$npm_execpath\" run test:packages && node \"$npm_execpath\" run type-check"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.7",
    "@gemini-wallet/core": "^0.3.2",
    "@metamask/sdk": "^0.33.1",
    "@reown/appkit": "^1.8.15",
    "@reown/appkit-adapter-bitcoin": "^1.8.15",
    "@reown/appkit-adapter-wagmi": "^1.8.15",
    "@solana/kit": "^3.0.3",
    "@stacks/connect": "^8.2.4",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@tanstack/react-query": "^5.90.12",
    "@walletconnect/ethereum-provider": "^2.21.10",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "latest": "^0.2.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.0",
    "porto": "^0.2.37",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.43.3",
    "wagmi": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
