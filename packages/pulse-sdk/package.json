{
  "name": "@winsznx/sdk",
  "version": "0.1.1",
  "description": "The official Pulse Protocol SDK for Base and Stacks interaction.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "pulse",
    "sdk",
    "base",
    "stacks",
    "web3"
  ],
  "author": "PULSE Team",
  "license": "MIT",
  "repository": "https://github.com/winsznx/klock.git",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@stacks/transactions": "^7.3.1",
    "viem": "^2.43.3"
  }
}
