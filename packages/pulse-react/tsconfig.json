{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "baseUrl": ".",
    "paths": {
      "@winsznx/sdk": [
        "../pulse-sdk/dist/index.d.ts"
      ],
      "@winsznx/sdk/*": [
        "../pulse-sdk/dist/*"
      ]
    },
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": false,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
